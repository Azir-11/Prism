{
  "name": "@simple-prism/core",
  "version": "0.1.0",
  "description": "Generate a harmonious, contrast-aware design-token system from one or a few seed colors.",
  "keywords": [
    "accessibility",
    "apca",
    "color",
    "design-tokens",
    "oklch",
    "palette",
    "theme"
  ],
  "homepage": "https://github.com/Azir-11/Prism#readme",
  "bugs": "https://github.com/Azir-11/Prism/issues",
  "license": "MIT",
  "author": "青菜白玉汤",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Azir-11/Prism.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "culori": "^4.0.2"
  },
  "devDependencies": {
    "@types/culori": "^4.0.1"
  }
}

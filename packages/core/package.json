{
  "name": "@prism/core",
  "version": "0.1.0",
  "description": "Generate a harmonious, contrast-aware design-token system from one or a few seed colors.",
  "license": "MIT",
  "author": "青菜白玉汤",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "culori": "^4.0.2"
  },
  "devDependencies": {
    "@types/culori": "^4.0.1"
  }
}

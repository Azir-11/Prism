{
  "name": "@simple-prism/tailwind",
  "version": "0.1.4",
  "description": "Tailwind CSS v4 @theme adapter for Prism themes.",
  "keywords": [
    "color",
    "design-tokens",
    "oklch",
    "tailwind",
    "tailwindcss",
    "theme"
  ],
  "homepage": "https://prism-docs-gamma.vercel.app/api/tailwind",
  "bugs": "https://github.com/Azir-11/Prism/issues",
  "license": "MIT",
  "author": "青菜白玉汤",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Azir-11/Prism.git",
    "directory": "packages/tailwind"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@simple-prism/core": "workspace:*"
  }
}
